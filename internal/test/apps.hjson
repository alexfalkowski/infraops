{
  version: "2.0"
  applications: [
    {
      id: 11111111-1111-1111-1111-111111111111
      kind: internal
      name: atlas
      namespace: fiction
      domain: example.net
      version: "9.9.9"
      resource: small
      secrets: [
        database
      ]
      env_vars: [
        {
          name: LOG_LEVEL
          value: info
        }
        {
          name: DATABASE_PASSWORD
          value: "secret:database/password"
        }
      ]
    }
    {
      id: 22222222-2222-2222-2222-222222222222
      kind: internal
      name: beacon
      namespace: fiction
      domain: example.net
      version: "8.8.8"
      resource: unknown
      env_vars: [
        {
          name: FEATURE_FLAG
          value: enabled
        }
      ]
    }
    {
      id: 33333333-3333-3333-3333-333333333333
      kind: external
      name: courier
      namespace: fiction
      domain: example.net
      version: "7.7.7"
      env_vars: [
        {
          name: UPSTREAM_URL
          value: "https://api.example.net"
        }
      ]
    }
  ]
}
